# Optional: canonical site URL for links/metadata when you add them
# PUBLIC_APP_URL=https://localhost:5173

# Convex — shared dev deployment for this repo (see .env.convex).
# Copy to .env.local as PUBLIC_CONVEX_URL so SvelteKit can query Convex.
# PUBLIC_CONVEX_URL=https://gregarious-iguana-339.convex.cloud

# Sentry error tracking (optional — leave empty to disable)
# Get your DSN from https://sentry.io after creating a project
# VITE_SENTRY_DSN=https://key@sentry.io/project-id
# SENTRY_DSN=https://key@sentry.io/project-id (same as above, for server-side)

# Rate limiting via Upstash Redis (optional — leave empty to disable)
# Sign up free at https://upstash.com (no credit card needed)
# Create a Redis database, then copy the REST API credentials below
# UPSTASH_REDIS_REST_URL=https://example.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# WorkOS Authentication (social logins: Google, Microsoft, GitHub, Facebook)
# Sign up free at https://workos.com
# Create a new WorkOS organization and get your API key
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...
# For local dev, use: http://localhost:5173
# For production, use your Vercel domain
# PUBLIC_WORKOS_REDIRECT_URI=http://localhost:5173/auth/callback
