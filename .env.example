# Optional: canonical site URL for Open Graph / canonical links (SiteMeta in root layout)
# PUBLIC_APP_URL=https://localhost:5173

# Convex — shared dev deployment for this repo (see .env.convex).
# Copy to .env.local as PUBLIC_CONVEX_URL so SvelteKit can query Convex.
# PUBLIC_CONVEX_URL=https://gregarious-iguana-339.convex.cloud

# Sentry error tracking (optional — leave empty to disable)
# Prefer the Vercel → Sentry integration, which injects NEXT_PUBLIC_SENTRY_DSN,
# SENTRY_AUTH_TOKEN, SENTRY_ORG, and SENTRY_PROJECT. This app also accepts:
# VITE_SENTRY_DSN=https://key@o0.ingest.sentry.io/project-id
# PUBLIC_SENTRY_DSN=https://key@o0.ingest.sentry.io/project-id
# NEXT_PUBLIC_SENTRY_DSN=https://key@o0.ingest.sentry.io/project-id
# SENTRY_DSN=https://key@o0.ingest.sentry.io/project-id
# SENTRY_AUTH_TOKEN=sntrys_...   # source maps on production builds
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# Rate limiting via Upstash Redis (optional locally; recommended in production)
# Sign up free at https://upstash.com (no credit card needed)
# Create a Redis database, then copy the REST API credentials below
# Without these in production (`VERCEL_ENV=production`), rate-limited routes return 429.
# Locally / preview, missing credentials fail open (allow traffic).
# UPSTASH_REDIS_REST_URL=https://example.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# WorkOS Authentication (social logins: Google, Microsoft, GitHub)
# Sign up free at https://workos.com
# Create a new WorkOS organization and get your API key + client ID
# Redirect URI is derived at runtime: {request origin}/auth/callback
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...

# Admin bootstrap (Convex env — not SvelteKit .env.local)
# Comma-separated emails promoted to admin on first OAuth login.
# Also set WORKOS_CLIENT_ID in Convex env for full-mock JWT validation.
# Set with:
#   npx convex env set ADMIN_EMAILS you@cityofdallas.gov
#   npx convex env set WORKOS_CLIENT_ID client_...
# ADMIN_EMAILS=you@cityofdallas.gov

# --- Cursor MCP (project: .cursor/mcp.json) ---
# Set in your shell profile, or copy to .env.mcp.local (gitignored).
# Convex MCP: optional deploy key to scope access to one deployment (else uses `npx convex login`).
# CONVEX_DEPLOY_KEY=dev:your-deployment|...
# Upstash MCP: account email + API key from https://console.upstash.com/account/api
# UPSTASH_EMAIL=you@example.com
# UPSTASH_API_KEY=your_upstash_api_key
# WorkOS MCP: OAuth on first connect in Cursor — no env vars required (https://mcp.workos.com/mcp)
