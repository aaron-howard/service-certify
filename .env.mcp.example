# Local MCP credentials for Cursor (.cursor/mcp.json).
# Copy to .env.mcp.local (gitignored) or export these in your shell profile.
#
# Convex — optional; omit to use global `npx convex login` instead.
# CONVEX_DEPLOY_KEY=dev:your-deployment|...

# Upstash — required for the Upstash MCP server (rate-limit Redis debugging).
UPSTASH_EMAIL=you@example.com
UPSTASH_API_KEY=your_upstash_api_key

# WorkOS MCP uses OAuth in Cursor; no secrets here.

# Semgrep — AppSec Platform API token for MCP (findings, scans).
# Create at https://semgrep.dev/orgs/-/settings/tokens or run `semgrep login`.
SEMGREP_APP_TOKEN="0fcc565f8038a28833f01505d847cb2a53ede229cf404ea8ae0ebfb75ae15fea"
