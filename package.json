{
	"name": "service-certify",
	"private": true,
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"postinstall": "patch-package",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"seed:dev": "convex run --push internal.seed.apply",
		"seed:dev:questions": "convex run --push internal.seed.devQuestions",
		"convex:dev": "convex dev",
		"convex:codegen": "convex codegen"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"patch-package": "^8.0.1",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"convex": "^1.34.0",
		"convex-svelte": "^0.0.12"
	}
}
