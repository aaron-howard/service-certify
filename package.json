{
	"name": "service-certify",
	"private": true,
	"version": "0.0.1",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22.11.0"
	},
	"overrides": {
		"cookie": "0.7.2",
		"ws": "8.21.0",
		"esbuild": "0.28.1"
	},
	"scripts": {
		"dev": "vite dev",
		"audit": "npm audit --audit-level=moderate",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
		"postinstall": "patch-package",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"verify:workos-env": "node scripts/verify-workos-env.mjs",
		"verify:upstash": "node scripts/verify-upstash-ratelimit.mjs",
		"verify:convex-auth-env": "node scripts/verify-convex-auth-env.mjs",
		"verify:convex-auth-env:prod": "node scripts/verify-convex-auth-env.mjs --prod",
		"seed:dev": "convex run --push --env-file .env.convex internal.seed.apply",
		"seed:dev:questions": "convex run --push --env-file .env.convex internal.seed.devQuestions",
		"seed:prod": "convex run --deployment prod internal.seed.apply && convex run --deployment prod internal.seed.devQuestions",
		"convex:dev": "convex dev --env-file .env.convex",
		"convex:select-dev": "convex deployment select gregarious-iguana-339",
		"convex:codegen": "convex codegen"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/svelte": "^5.4.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"happy-dom": "^20.10.6",
		"jsdom": "^29.1.1",
		"patch-package": "^8.0.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^7.0.2",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/material-symbols-outlined": "^5.2.45",
		"@sentry/sveltekit": "^10.65.0",
		"@upstash/redis": "^1.38.0",
		"@vercel/speed-insights": "^2.0.0",
		"@workos-inc/node": "^10.7.0",
		"convex": "^1.42.1",
		"convex-svelte": "^0.14.0"
	}
}
